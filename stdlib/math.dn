fn sqrt(value: real64) -> real64 {
    if value <= 0.0 {
        return 0.0;
    }

    let guess: real64 = value;
    let index = 0;
    while index < 24 {
        guess = (guess + value / guess) / 2.0;
        index = index + 1;
    }

    return guess;
}

fn sqrt(value: real32) -> real32 {
    if value <= 0.0 {
        return 0.0;
    }

    let guess: real32 = value;
    let index = 0;
    while index < 16 {
        guess = (guess + value / guess) / 2.0;
        index = index + 1;
    }

    return guess;
}

fn normalize_radians(value: real64) -> real64 {
    let x: real64 = value;

    while x > PI {
        x = x - TAU;
    }

    while x < 0.0 - PI {
        x = x + TAU;
    }

    return x;
}

fn normalize_radians(value: real32) -> real32 {
    let x: real32 = value;

    while x > PI32 {
        x = x - TAU32;
    }

    while x < 0.0 - PI32 {
        x = x + TAU32;
    }

    return x;
}

fn sin(value: real64) -> real64 {
    let x: real64 = normalize_radians(value);
    let term: real64 = x;
    let sum: real64 = x;
    let n: real64 = 1.0;

    while n < 12.0 {
        let a: real64 = 2.0 * n;
        let b: real64 = 2.0 * n + 1.0;
        term = (0.0 - term) * x * x / (a * b);
        sum = sum + term;
        n = n + 1.0;
    }

    return sum;
}

fn sin(value: real32) -> real32 {
    let x: real32 = normalize_radians(value);
    let term: real32 = x;
    let sum: real32 = x;
    let n: real32 = 1.0;

    while n < 8.0 {
        let a: real32 = 2.0 * n;
        let b: real32 = 2.0 * n + 1.0;
        term = (0.0 - term) * x * x / (a * b);
        sum = sum + term;
        n = n + 1.0;
    }

    return sum;
}

fn cos(value: real64) -> real64 {
    let x: real64 = normalize_radians(value);
    let term: real64 = 1.0;
    let sum: real64 = 1.0;
    let n: real64 = 1.0;

    while n < 12.0 {
        let a: real64 = 2.0 * n - 1.0;
        let b: real64 = 2.0 * n;
        term = (0.0 - term) * x * x / (a * b);
        sum = sum + term;
        n = n + 1.0;
    }

    return sum;
}

fn cos(value: real32) -> real32 {
    let x: real32 = normalize_radians(value);
    let term: real32 = 1.0;
    let sum: real32 = 1.0;
    let n: real32 = 1.0;

    while n < 8.0 {
        let a: real32 = 2.0 * n - 1.0;
        let b: real32 = 2.0 * n;
        term = (0.0 - term) * x * x / (a * b);
        sum = sum + term;
        n = n + 1.0;
    }

    return sum;
}

fn tan(value: real64) -> real64 {
    return sin(value) / cos(value);
}

fn tan(value: real32) -> real32 {
    return sin(value) / cos(value);
}

fn exp(value: real64) -> real64 {
    let x: real64 = value;
    let scale = 0;

    while x > 1.0 {
        x = x - 1.0;
        scale = scale + 1;
    }

    while x < 0.0 - 1.0 {
        x = x + 1.0;
        scale = scale - 1;
    }

    let term: real64 = 1.0;
    let sum: real64 = 1.0;
    let n: real64 = 1.0;
    while n < 28.0 {
        term = term * x / n;
        sum = sum + term;
        n = n + 1.0;
    }

    while scale > 0 {
        sum = sum * E;
        scale = scale - 1;
    }

    while scale < 0 {
        sum = sum / E;
        scale = scale + 1;
    }

    return sum;
}

fn exp(value: real32) -> real32 {
    let x: real32 = value;
    let scale = 0;
    let negative_one: real32 = 0.0 - 1.0;

    while x > 1.0 {
        x = x - 1.0;
        scale = scale + 1;
    }

    while x < negative_one {
        x = x + 1.0;
        scale = scale - 1;
    }

    let term: real32 = 1.0;
    let sum: real32 = 1.0;
    let n: real32 = 1.0;
    while n < 18.0 {
        term = term * x / n;
        sum = sum + term;
        n = n + 1.0;
    }

    while scale > 0 {
        sum = sum * E32;
        scale = scale - 1;
    }

    while scale < 0 {
        sum = sum / E32;
        scale = scale + 1;
    }

    return sum;
}

fn ln(value: real64) -> real64 {
    if value <= 0.0 {
        return 0.0;
    }

    let x: real64 = value;
    let scale_value: real64 = 0.0;

    while x > E {
        x = x / E;
        scale_value = scale_value + 1.0;
    }

    while x < INVERSE_E {
        x = x * E;
        scale_value = scale_value - 1.0;
    }

    let y: real64 = (x - 1.0) / (x + 1.0);
    let y2: real64 = y * y;
    let term: real64 = y;
    let sum: real64 = 0.0;
    let n: real64 = 1.0;

    while n < 39.0 {
        sum = sum + term / n;
        term = term * y2;
        n = n + 2.0;
    }

    return 2.0 * sum + scale_value;
}

fn ln(value: real32) -> real32 {
    if value <= 0.0 {
        return 0.0;
    }

    let x: real32 = value;
    let scale_value: real32 = 0.0;

    while x > E32 {
        x = x / E32;
        scale_value = scale_value + 1.0;
    }

    while x < INVERSE_E32 {
        x = x * E32;
        scale_value = scale_value - 1.0;
    }

    let y: real32 = (x - 1.0) / (x + 1.0);
    let y2: real32 = y * y;
    let term: real32 = y;
    let sum: real32 = 0.0;
    let n: real32 = 1.0;

    while n < 25.0 {
        sum = sum + term / n;
        term = term * y2;
        n = n + 2.0;
    }

    return 2.0 * sum + scale_value;
}

fn pow(base: real64, exponent: int) -> real64 {
    let result: real64 = 1.0;
    let count = exponent;
    if count < 0 {
        count = 0 - count;
    }

    while count > 0 {
        result = result * base;
        count = count - 1;
    }

    if exponent < 0 {
        return 1.0 / result;
    }

    return result;
}

fn pow(base: real32, exponent: int) -> real32 {
    let result: real32 = 1.0;
    let count = exponent;
    if count < 0 {
        count = 0 - count;
    }

    while count > 0 {
        result = result * base;
        count = count - 1;
    }

    if exponent < 0 {
        return 1.0 / result;
    }

    return result;
}

fn pow(base: real64, exponent: real64) -> real64 {
    return exp(exponent * ln(base));
}

fn pow(base: real32, exponent: real32) -> real32 {
    return exp(exponent * ln(base));
}

fn floor(value: real64) -> real64 {
    let result: real64 = 0.0;
    if value >= 0.0 {
        while result + 1.0 <= value {
            result = result + 1.0;
        }
        return result;
    }

    while result > value {
        result = result - 1.0;
    }
    return result;
}

fn floor(value: real32) -> real32 {
    let result: real32 = 0.0;
    if value >= 0.0 {
        while result + 1.0 <= value {
            result = result + 1.0;
        }
        return result;
    }

    while result > value {
        result = result - 1.0;
    }
    return result;
}

fn ceil(value: real64) -> real64 {
    let result: real64 = floor(value);
    if result < value {
        return result + 1.0;
    }

    return result;
}

fn ceil(value: real32) -> real32 {
    let result: real32 = floor(value);
    if result < value {
        return result + 1.0;
    }

    return result;
}

fn round(value: real64) -> real64 {
    if value >= 0.0 {
        return floor(value + 0.5);
    }

    return ceil(value - 0.5);
}

fn round(value: real32) -> real32 {
    if value >= 0.0 {
        return floor(value + 0.5);
    }

    return ceil(value - 0.5);
}
