const PI: real64 = 3.141592653589793;
const TAU: real64 = PI * 2.0;
const E: real64 = 2.718281828459045;
const INVERSE_E: real64 = 1.0 / E;
const PI32: real32 = 3.1415927;
const TAU32: real32 = PI32 * 2.0;
const E32: real32 = 2.7182817;
const INVERSE_E32: real32 = 1.0 / E32;

