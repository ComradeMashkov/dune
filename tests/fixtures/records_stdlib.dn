import assert;
import collections;
import maybe;
import outcome;

record Point {
    x: int,
    y: int,

    sum(): int {
        return this.x + this.y;
    }
}

point: Point := Point { x: 10, y: 20 };
print(point.x);
print(point.sum());

maybe_value: maybe.Maybe<int> := maybe.present(42);
missing: maybe.Maybe<int> := maybe.absent(0);
print(maybe_value.value_or(0));
print(missing.value_or(7));
print(maybe_value.has_value());
print(missing.is_absent());
print(when maybe_value.value_or(0) {
    is 42 { 100 }
    is _ { 0 }
});

done: outcome.Outcome<int, text> := outcome.done(9, "");
failed: outcome.Outcome<int, text> := outcome.failed(0, "bad");
print(done.value_or(0));
print(failed.value_or(5));
print(failed.failure_or("absent"));
print(when failed.failure_or("absent") {
    is "bad" { 1 }
    is _ { 0 }
});

repeated: [int] := collections.repeat_int(3, 4);
print(repeated.len());
print(assert.equals_int(repeated[0], 3));
