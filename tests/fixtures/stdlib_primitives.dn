import array;
import feature_exports;
import text;

foreign func c_sqrt(value: real64): real64 = "sqrt";

var message: text = "dune language";
print(message[0]);
print(message[5:13]);
print(message[:4]);
print(message[5:]);

var values: [int] = [1, 2, 3, 4, 5];
var middle: [int] = values[1:4];
print(middle.len());
print(middle[0]);
print(middle[2]);
print(array.sum(middle));
print(array.contains(middle, 3));
print(array.index_of(middle, 4));
var reversed: [int] = array.reverse(middle);
print(array.first(reversed));
print(array.last(reversed));
var ranged: [int] = array.range(2, 5);
print(array.sum(ranged));

var total = 0;
for var i = 0; i < 6; i = i + 1 {
    if i == 1 {
        continue;
    }

    if i == 4 {
        break;
    }

    total = total + i;
}
print(total);

print(c_sqrt(81.0));
print(text.ends_with(message, "language"));
print(text.index_of(message, 'g'));
print(text.count(message, 'a'));
print(text.trim("  dune  "));
print(feature_exports.ANSWER);
print(feature_exports.public());
