import math;

values: [int] := [1, math.square(2), 5];
base: u64 := 7;
values.push(math.square(values[2]));

print(values.len());
print(values[1]);
print(values[3]);
print(math.square(base));
print(math.square(1.5));
print(math.abs(0 - 8));
print(math.cube(3));
print(math.min(4, 9));
print(math.max(4, 9));
print(math.clamp(12, 0, 10));

rough: real32 := 1.5;
print(math.max(rough, 2.5));
print(math.abs(0.0 - 2.5));
print(math.round(math.PI));
print(math.floor(2.9));
print(math.ceil(2.1));
print(math.sqrt(9.0));
print(math.pow(2.0, 3));
print(math.sin(0.0));
print(math.cos(0.0));
print(math.tan(0.0));
print(math.exp(0.0));
print(math.ln(1.0));
print(math.normalize_radians(math.TAU));
