import array;
import math;

// Generic functions are instantiated only for call sites.
fn identity<T>(value: T): T {
    return value;
}

fn twice<T is numeric>(value: T): T {
    return value + value;
}

words: [text] = ["dune", "lang"];
reversed: [text] = array.reverse(words);
rough: real32 = 1.5;

print(identity(42));
print(identity("done"));
print(reversed.first());
print(math.square(12));
print(math.square(rough));
print(twice(9));
