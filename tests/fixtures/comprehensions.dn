nums: [int] = [1, 2, 3, 4, 5];

squares: [int] = [n * n for n in nums];
print(squares.len());
print(squares[0]);
print(squares[4]);

evens: [int] = [n for n in nums if n % 2 == 0];
print(evens.len());
print(evens[0]);
print(evens[1]);

ranged: [int] = [i * 2 for i in 0..5];
print(ranged.len());
print(ranged[0]);
print(ranged[4]);

empty: [int] = [n for n in nums if n > 100];
print(empty.len());

words: [text] = [w for w in ["a", "bb", "ccc"] if w.len() > 1];
print(words.len());
print(words[0]);
print(words[1]);

nested: [[int]] = [[x for x in 0..r] for r in 1..4];
print(nested.len());
print(nested[0].len());
print(nested[1].len());
print(nested[2].len());
print(nested[2][2]);
