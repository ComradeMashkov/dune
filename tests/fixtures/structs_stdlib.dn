import assert;
import collections;
import option;
import result;

struct Point {
    x: int,
    y: int,
}

impl Point {
    fn sum() -> int {
        return self.x + self.y;
    }
}

let point: Point = Point { x: 10, y: 20 };
print(point.x);
print(point.sum());

let maybe: option.Option<int> = option.some(42);
let missing: option.Option<int> = option.none(0);
print(maybe.unwrap_or(0));
print(missing.unwrap_or(7));
print(maybe.is_some());
print(missing.is_none());
print(match maybe.unwrap_or(0) { 42 => 100, _ => 0, });

let ok: result.Result<int, text> = result.ok(9, "");
let err: result.Result<int, text> = result.err(0, "bad");
print(ok.unwrap_or(0));
print(err.unwrap_or(5));
print(err.error_or("none"));
print(match err.error_or("none") { "bad" => 1, _ => 0, });

let repeated: [int] = collections.repeat_int(3, 4);
print(repeated.len());
print(assert.equals_int(repeated[0], 3));
