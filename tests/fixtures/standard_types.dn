func say(message: text): unit {
    print(message);
    return;
}

func noop(): unit {
}

func next(value: i32): i32 {
    return value + 1;
}

var tiny: i8 = 12;
var small: i16 = 32000;
var mid: i32 = next(40);
var wide: i64 = 9000000000;
var count: usize = 5;
var offset: isize = 6;
var sample: real32 = 1.5;
var sample_sum: real32 = sample + 2.25;
var precise: real64 = 2.25;
var status: text = "same";

say("types");
noop();
print(tiny);
print(small);
print(mid);
print(wide);
print(count);
print(offset);
print(sample_sum);
print(precise);
if status == "same" {
    print(status);
} else {
    print("bad");
}
