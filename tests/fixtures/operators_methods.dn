var value = 17;
print(0 - value);
print(-value);
print(17 % 5);
print(!false);
print(false && (1 / 0 == 0));
print(true || (1 / 0 == 0));

var count: real64 = value to real64;
print(count / 2.0);

var code: int = 'A' to int;
var letter: glyph = 66 to glyph;
var flag: bool = 0 to bool;
print(code);
print(letter);
print(flag);

var values: [int] = [1, 2];
print(values.is_empty());
values.push(3);
print(values.pop());
print(values.len());
values.clear();
print(values.is_empty());

var message: text = "dune language";
print(message.len());
print(message.contains("lang"));
print(message.starts_with("dune"));
print("".is_empty());
