record Point {
  x: int,
  y: int,
}

values: [int] = [1];
alias = values;
alias[0] = 2;
print(values[0]);

const frozen: [int] = [5];
mutable_alias = frozen;
mutable_alias[0] = 6;
print(frozen[0]);

point: Point = Point { x: 3, y: 0 };
point_alias = point;
point_alias.x = 4;
print(point.x);

const fixed_point: Point = Point { x: 7, y: 0 };
mutable_point_alias = fixed_point;
mutable_point_alias.x = 9;
print(fixed_point.x);

scalar = 1;
scalar_copy = scalar;
scalar_copy = 2;
print(scalar);
print(scalar_copy);
