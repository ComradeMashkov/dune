import autograd;

x = autograd.variable(2.0);
y = autograd.variable(3.0);
loss = x.mul(y).add(x.pow(2.0)).add(1.0);
loss.backward();
print(loss.data);
print(x.grad);
print(y.grad);

a = autograd.variable(3.0);
shared = a.mul(a);
doubled = shared.add(shared);
doubled.backward();
print(doubled.data);
print(a.grad);
doubled.backward();
print(a.grad);

negative = autograd.variable(0.0 - 2.0);
clipped = negative.relu();
clipped.backward();
print(clipped.data);
print(negative.grad);
