export contract Shape {
    area(): real64;
}

export record Counter {
    value: int,

    export fn new(): Counter {
        return Counter { value: 0 };
    }

    export static fn zero(): Counter {
        return Counter { value: 0 };
    }

    static fn secret(): Counter {
        return Counter { value: -1 };
    }

    export fn inc(): unit {
        this.value = this.value + 1;
    }

    fn reset(): unit {
        this.value = 0;
    }

    export fn current(): int {
        return this.value;
    }
}

export record Circle with Shape {
    radius: real64,

    export fn new(radius: real64): Circle {
        return Circle { radius: radius };
    }

    export fn area(): real64 {
        return 3.0 * this.radius * this.radius;
    }
}
