choice Maybe {
    Present(int),
    Absent,
}

func fallback(value: Maybe, default: int): int {
    return case value {
        Present(x) : x,
        Absent : default,
    };
}

var x = 99;
var value: Maybe = Present(30);
var missing: Maybe = Absent;

print(fallback(value, 0));
print(fallback(missing, 7));
print(case value {
    Present(x) : x + 1,
    Absent : 0,
});
print(x);
