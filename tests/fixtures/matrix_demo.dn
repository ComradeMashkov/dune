import matrix;

v = matrix.vector([1, 2, 3]);
w = matrix.vector([4, 5, 6]);
sum = v.add(w);
print(sum.get(0));
print(sum.get(2));
print(v.dot(w));
print(v.shape()[0]);
print(v.same_shape(w));

scaled = v.scale(3);
print(scaled.get(1));
print(v.add(10).get(2));
print(v.rsub(10).get(0));
print(v.mul(w).get(1));
print(w.div(v).get(1));
print(v.concat(w).len());
print(v.slice(1, 3).sum());

u = matrix.vector([0 - 3, 2, 7]);
print(u.abs().get(0));
print(u.clip(0, 5).get(2));
print(u.min());
print(u.max());
print(u.argmin());
print(u.argmax());
print(u.product());

sequence = matrix.arange(1, 5);
print(sequence.sum());
reverse = matrix.arange(5, 1, 0 - 2);
print(reverse.get(1));

m = matrix.from_flat(2, 3, [1, 2, 3, 4, 5, 6]);
print(m.rows());
print(m.cols());
print(m.get(1, 2));
print(m.shape()[0]);
print(m.shape()[1]);
print(m.flatten().get(4));
print(m.reshape(3, 2).get(2, 0));
print(m.diagonal().sum());
print(m.trace());

t = m.transpose();
print(t.rows());
print(t.cols());
print(t.get(2, 1));

n = matrix.from_flat(3, 2, [7, 8, 9, 10, 11, 12]);
product = m.matmul(n);
print(product.get(0, 0));
print(product.get(1, 1));
print(m.can_matmul(n));
print(m.same_shape(n));
print(m.add(1).get(0, 2));
print(m.rsub(10).get(0, 0));
print(m.mul(m).get(1, 0));
print(m.div(2).get(1, 2));
print(m.clip(2, 5).get(0, 0));
print(m.clip(2, 5).get(1, 2));

mv = m.mul_vector(matrix.vector([1, 1, 1]));
print(mv.get(0));
print(mv.get(1));

z: matrix.Matrix<int> = matrix.zeros(2, 2);
print(z.sum());
ones: matrix.Matrix<int> = matrix.ones(2, 2);
print(ones.sum());

id: matrix.Matrix<int> = matrix.identity(3);
print(id.get(0, 0));
print(id.get(0, 1));
eye: matrix.Matrix<int> = matrix.eye(2);
print(eye.trace());
diag = matrix.diagonal(matrix.vector([2, 3]));
print(diag.get(1, 1));
print(diag.sum());
filled: matrix.Matrix<int> = matrix.full(2, 2, 1);
filled.fill(7);
print(filled.get(1, 1));
print(filled.equals(matrix.full(2, 2, 7)));

r = matrix.vector([1.5, 2.5]);
print(r.sum());
